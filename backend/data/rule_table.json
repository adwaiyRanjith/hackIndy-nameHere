{
  "rules": [
    {
      "rule_id": "entrance_door_width",
      "module": "entrance",
      "check_type": "measurement_minimum",
      "ada_section": "ADA Section 404.2.3",
      "element": "Door Clear Width",
      "description": "Door clear opening width must be at least 32 inches when open 90 degrees.",
      "severity": "critical",
      "remediation_cost_low": 700,
      "remediation_cost_high": 2500,
      "measurement_key": "door_clear_width_inches",
      "minimum": 32,
      "relative_field": "estimated_door_width_relative",
      "relative_violation_value": "narrow"
    },
    {
      "rule_id": "entrance_door_hardware",
      "module": "entrance",
      "check_type": "feature_value",
      "ada_section": "ADA Section 404.2.7",
      "element": "Door Hardware",
      "description": "Door hardware must be operable with one hand and not require tight grasping, pinching, or twisting of the wrist.",
      "severity": "high",
      "remediation_cost_low": 75,
      "remediation_cost_high": 200,
      "gemini_field": "handle_type",
      "prohibited_values": [
        "round_knob"
      ]
    },
    {
      "rule_id": "entrance_threshold",
      "module": "entrance",
      "check_type": "feature_presence",
      "ada_section": "ADA Section 404.2.5",
      "element": "Door Threshold",
      "description": "Thresholds at doorways must not exceed 0.5 inch in height. Flag if a raised threshold is visible.",
      "severity": "medium",
      "remediation_cost_low": 100,
      "remediation_cost_high": 400,
      "gemini_field": "threshold_appears_raised",
      "flag_if_true": true
    },
    {
      "rule_id": "entrance_signage_isa",
      "module": "entrance",
      "check_type": "feature_presence",
      "ada_section": "ADA Section 216.6",
      "element": "ISA Accessibility Symbol",
      "description": "Accessible entrances must be identified with the International Symbol of Accessibility.",
      "severity": "medium",
      "remediation_cost_low": 50,
      "remediation_cost_high": 150,
      "gemini_field": "signage_isa_symbol_present",
      "flag_if_false": true
    },
    {
      "rule_id": "entrance_ramp_handrails",
      "module": "entrance",
      "check_type": "feature_presence",
      "ada_section": "ADA Section 405.8",
      "element": "Ramp Handrails",
      "description": "Ramps with a rise greater than 6 inches must have handrails on both sides.",
      "severity": "high",
      "remediation_cost_low": 500,
      "remediation_cost_high": 2000,
      "gemini_field": "handrails_both_sides",
      "flag_if_false": true,
      "condition_field": "ramp_present",
      "condition_value": true
    },
    {
      "rule_id": "restroom_grab_bars",
      "module": "restroom",
      "check_type": "feature_presence",
      "ada_section": "ADA Section 604.5",
      "element": "Toilet Grab Bars",
      "description": "Grab bars must be provided at the side and rear of the toilet.",
      "severity": "critical",
      "remediation_cost_low": 200,
      "remediation_cost_high": 500,
      "gemini_field": "grab_bars_present",
      "flag_if_false": true
    },
    {
      "rule_id": "restroom_faucet_type",
      "module": "restroom",
      "check_type": "feature_value",
      "ada_section": "ADA Section 606.4",
      "element": "Faucet Controls",
      "description": "Faucet controls must be operable with one hand without tight grasping, pinching, or twisting.",
      "severity": "high",
      "remediation_cost_low": 100,
      "remediation_cost_high": 300,
      "gemini_field": "faucet_type",
      "prohibited_values": [
        "knob"
      ]
    },
    {
      "rule_id": "restroom_door_swing",
      "module": "restroom",
      "check_type": "feature_value",
      "ada_section": "ADA Section 603.2.2",
      "element": "Restroom Door Swing",
      "description": "Doors in single-user toilet rooms must not swing into the required clear floor space of any fixture.",
      "severity": "high",
      "remediation_cost_low": 300,
      "remediation_cost_high": 800,
      "gemini_field": "door_swings",
      "prohibited_values": [
        "inward"
      ]
    },
    {
      "rule_id": "restroom_clearance",
      "module": "restroom",
      "check_type": "measurement_minimum",
      "ada_section": "ADA Section 604.3",
      "element": "Floor Turning Radius",
      "description": "A turning space of at least 60 inches in diameter must be provided within the restroom.",
      "severity": "critical",
      "remediation_cost_low": 2000,
      "remediation_cost_high": 8000,
      "measurement_key": "clearance_inches",
      "minimum": 60,
      "relative_field": "estimated_clearance_relative",
      "relative_violation_value": "tight"
    },
    {
      "rule_id": "restroom_mirror_height",
      "module": "restroom",
      "check_type": "feature_presence",
      "ada_section": "ADA Section 603.3",
      "element": "Mirror Height",
      "description": "Mirror bottom edge must be mounted no higher than 40 inches above the floor for accessible use.",
      "severity": "low",
      "remediation_cost_low": 50,
      "remediation_cost_high": 150,
      "gemini_field": "mirror_appears_tilted",
      "flag_if_false": true,
      "condition_field": "mirror_detected",
      "condition_value": true
    },
    {
      "rule_id": "parking_space_count",
      "module": "parking",
      "check_type": "count_minimum",
      "ada_section": "ADA Section 208.2",
      "element": "Accessible Parking Spaces",
      "description": "A minimum number of accessible parking spaces are required based on the total lot size.",
      "severity": "critical",
      "remediation_cost_low": 500,
      "remediation_cost_high": 1500,
      "gemini_field": "accessible_spaces_detected",
      "count_lookup": "parking_space_count"
    },
    {
      "rule_id": "parking_signage",
      "module": "parking",
      "check_type": "feature_presence",
      "ada_section": "ADA Section 502.6",
      "element": "Accessible Parking Signage",
      "description": "Each accessible parking space must be identified by a vertical sign with the ISA symbol mounted at least 60 inches above the ground.",
      "severity": "high",
      "remediation_cost_low": 150,
      "remediation_cost_high": 300,
      "gemini_field": "vertical_sign_present",
      "flag_if_false": true
    },
    {
      "rule_id": "parking_van_accessible",
      "module": "parking",
      "check_type": "feature_presence",
      "ada_section": "ADA Section 208.2.4",
      "element": "Van-Accessible Space",
      "description": "At least one accessible space must be van-accessible, with a minimum 98-inch vertical clearance and an 8-foot access aisle.",
      "severity": "high",
      "remediation_cost_low": 200,
      "remediation_cost_high": 500,
      "gemini_field": "van_accessible_sign_present",
      "flag_if_false": true
    },
    {
      "rule_id": "parking_access_aisle",
      "module": "parking",
      "check_type": "feature_presence",
      "ada_section": "ADA Section 502.3",
      "element": "Parking Access Aisle",
      "description": "An access aisle must be provided adjacent to each accessible parking space.",
      "severity": "critical",
      "remediation_cost_low": 300,
      "remediation_cost_high": 800,
      "gemini_field": "access_aisle_visible",
      "flag_if_false": true
    },
    {
      "rule_id": "parking_curb_ramp",
      "module": "parking",
      "check_type": "feature_presence",
      "ada_section": "ADA Section 406.1",
      "element": "Curb Ramp to Entrance",
      "description": "A curb ramp or blended transition must be provided where the accessible route crosses a curb.",
      "severity": "high",
      "remediation_cost_low": 1000,
      "remediation_cost_high": 3000,
      "gemini_field": "curb_ramp_present",
      "flag_if_false": true
    }
